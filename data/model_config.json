{
  "version": "1.0.0",
  "created": "2026-01-24",
  "description": "Unified model configuration for Eidosian Forge",

  "ollama": {
    "base_url": "http://localhost:11434",
    "api_v1_url": "http://localhost:11434/v1"
  },

  "inference": {
    "model": "qwen3.5:2b",
    "max_tokens": 4096,
    "temperature": 0.7,
    "thinking_mode": "off",
    "description": "Primary inference model for reasoning, extraction, generation with normalized reasoning-channel handling"
  },

  "embedding": {
    "model": "nomic-embed-text",
    "dimensions": 768,
    "context_length": 8192,
    "description": "Primary embedding model for semantic search and retrieval"
  },

  "fast_embedding": {
    "model": "all-minilm",
    "dimensions": 384,
    "context_length": 512,
    "description": "Lightweight embedding for quick/batch operations"
  },

  "local_inference": {
    "model_path": "/data/data/com.termux/files/home/eidosian_forge/models/Qwen2.5-1.5B-Instruct-Q8_0.gguf",
    "llama_cli_path": "/data/data/com.termux/files/home/eidosian_forge/llama.cpp/build/bin/llama-cli",
    "llama_bench_path": "/data/data/com.termux/files/home/eidosian_forge/llama.cpp/build/bin/llama-bench",
    "prefer_llama_cpp": true,
    "description": "Central local llama.cpp configuration until a Qwen3.5 GGUF artifact is installed"
  },

  "graphrag": {
    "chat_model": "qwen3.5:2b",
    "embedding_model": "nomic-embed-text",
    "encoding_model": "cl100k_base"
  },

  "forges": {
    "memory_forge": {
      "embedding_model": "nomic-embed-text",
      "notes": "Uses Ollama for embeddings instead of HuggingFace"
    },
    "knowledge_forge": {
      "embedding_model": "nomic-embed-text",
      "inference_model": "qwen3.5:2b"
    },
    "word_forge": {
      "embedding_model": "nomic-embed-text",
      "inference_model": "qwen3.5:2b"
    },
    "llm_forge": {
      "default_model": "qwen3.5:2b",
      "embedding_model": "nomic-embed-text"
    },
    "agent_forge": {
      "default_model": "qwen3.5:2b"
    }
  }
}
